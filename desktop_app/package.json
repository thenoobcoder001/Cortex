{
  "name": "cortex",
  "version": "0.0.1",
  "private": true,
  "main": "electron/main.js",
  "description": "Unified AI coding assistant desktop app",
  "author": "CHIRAG",
  "scripts": {
    "dev:web": "vite --config web/vite.config.js",
    "dev:backend": "node backend/start_standalone.js",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npx cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 npx electron electron/main.js",
    "dev": "npx concurrently -k \"npm:dev:web\" \"npm:dev:electron\" \"npm:dev:backend\"",
    "build:web": "vite build --config web/vite.config.js",
    "build": "npm run build:web && electron-builder",
    "start": "electron electron/main.js"
  },
  "build": {
    "appId": "com.chirag.cortex",
    "productName": "Cortex",
    "icon": "build/icon.png",
    "files": [
      "backend/**/*",
      "!backend/**/*.test.js",
      "electron/**/*",
      "web/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^10.0.0",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.0",
    "wait-on": "^8.0.3"
  }
}
